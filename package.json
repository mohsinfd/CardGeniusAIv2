{
  "name": "cardgenius-ai",
  "version": "1.0.0",
  "description": "CardGenius AI - Credit Card Rewards Calculator",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "test": "jest",
    "build": "tsc && vite build",
    "build:api": "tsc -p tsconfig.api.json",
    "start": "node dist/api/main.js",
    "dev": "vite",
    "dev:api": "ts-node -P tsconfig.api.json src/api/main.ts",
    "preview": "vite preview",
    "copy-duckdb": "node scripts/copy-duckdb.js",
    "predev": "npm run copy-duckdb"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.29.0",
    "apache-arrow": "^14.0.1",
    "cors": "^2.8.5",
    "dompurify": "^3.0.8",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "marked": "^11.1.1",
    "openai": "^4.24.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
